// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  /** 自動更新を有効にする */
  "auto_update": true,
  "theme": {
    "mode": "system",
    "light": "JetBrains New Dark",
    "dark": "One Dark"
  },
  /** vim mode を有効にする */
  "vim_mode": true,
  /** font-size */
  "ui_font_size": 12,
  "buffer_font_size": 12,
  /** font family を JetBrainsMono Nerd Font にする */
  "ui_font_family": "JetBrainsMono Nerd Font",
  "terminal_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_family": "JetBrainsMono Nerd Font",
  /** カーソルがある行からの相対的な行数を表示する */
  "relative_line_numbers": true,
  /** スクロールバーを非表示にする */
  "scrollbar": {
    "show": "never"
  },
  /** ターミナルの設定 */
  "terminal": {
    /** ツールバーのパンくずを非表示にする */
    "toolbar": {
      "breadcrumbs": false
    }
  },
  /** インレイヒントを表示する */
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true
  },
  /** tsserver の path を global なものに設定する */
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "tsdk": "~/.nvm/versions/node/v21.7.3/lib/node_modules/typescript/lib"
        }
      }
    }
  }
}
