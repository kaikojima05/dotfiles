// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  /** 自動更新を有効にする */
  "show_inline_completions": true,
  "auto_update": true,
  "theme": {
    "mode": "system",
    "light": "Solarized Dark",
    "dark": "One Dark"
  },
  /** vim mode を有効にする */
  "vim_mode": true,
  /** font-size */
  "ui_font_size": 12,
  "buffer_font_size": 12,
  /** font family を JetBrainsMono Nerd Font にする */
  "ui_font_family": "JetBrainsMono Nerd Font",
  "terminal_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_family": "JetBrainsMono Nerd Font",
  /** 非アクティブなパネルの透明度 */
  "inactive_opacity": 0.7,
  /** カーソルがある行からの相対的な行数を表示する */
  "relative_line_numbers": true,
  /** ターミナルの設定 */
  "terminal": {
    /** ツールバーのパンくずを非表示にする */
    "toolbar": {
      "breadcrumbs": false
    }
  },
  /** インレイヒントを表示する */
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true
  },
  /** tsserver の path を global なものに設定する */
  /** vtsls の設定は一時凌ぎなので、正規の方法が出てきた時に変更する */
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "tsdk": "~/.nvm/versions/node/v21.7.3/lib/node_modules/typescript/lib"
        }
      }
    },
    "typos": {
      "initialization_options": {
        "config": "/Users/kaikojima/.config/nvim/spell/.typos.toml",
        "path": "/opt/homebrew/bin/typos-lsp",
        "diagnosticSeverity": "Error",
        "trace.server": "off"
      }
    }
  }
}
