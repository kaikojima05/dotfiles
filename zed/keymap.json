[
  /** insert mode */
  {
    "context": "Editor && vim_mode == insert && !VimWaiting && !menu",
    "bindings": {
      /** insert mode の状態のまま1文字進む */
      "ctrl-l": ["workspace::SendKeystrokes", "escape l a"],
      /** ,（カンマ）の右に半角スペースを挿入する */
      ",": ["workspace::SendKeystrokes", ", space"]
    }
  },
  /** normal mode */
  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual) && !VimWaiting && !menu",
    "bindings": {
      /** 行頭に移動 */
      "space h": "editor::MoveToBeginningOfLine",
      /** 行末に移動 */
      "space l": "editor::MoveToEndOfLine",
      /** 画面を縦に分割する */
      "space v v": "pane::SplitVertical",
      /** fold の開閉 */
      "ctrl-[": "editor::ToggleFold",
      /** error 箇所にジャンプ */
      "E": "editor::GoToDiagnostic",
      /** カーソルから右側を削除する */
      "d l": "vim::DeleteToEndOfLine",
      /** カーソルから左側を削除する */
      "d h": "editor::DeleteToBeginningOfLine",
      /** LSP のジャンプ機能 */
      "space r k": "editor::GoToDefinition",
      /** ジャンプ元に戻る */
      "space b k": "pane::GoBack",
      /** ファイル検索 */
      "space f": [
        "task::Spawn",
        { "task_name": "File Finder", "reveal_target": "center" }
      ],
      /** 単語検索 */
      "space r": ["workspace::SendKeystrokes", "cmd-shift-f"]
      /** 単語検索時にマッチした単語を移動する */
    }
  },
  /** 一致検索時の移動 */
  {
    "context": "Editor",
    "bindings": {
      /** 戻る */
      "p": "search::SelectPrevMatch",
      /** 進む */
      "n": "search::SelectNextMatch"
    }
  }
]
